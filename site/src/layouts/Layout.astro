---
import '../styles/global.css';
import '../../../dist/css/variables.css';
import '../../../dist/css/variables.dark.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | ReadMigo Brand Hub</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    // Initialize theme from localStorage before paint to prevent flash
    (function() {
      var theme = localStorage.getItem('theme');
      if (theme === 'dark' || theme === 'light') {
        document.documentElement.setAttribute('data-theme', theme);
      }
    })();
  </script>
</head>
<body
  class="min-h-screen"
  style="background-color: var(--semantic-surface-background, #F7F8FD); color: var(--semantic-text-primary, #2D2E4A);"
>
  <nav
    class="sticky top-0 z-50 border-b backdrop-blur"
    style="border-color: var(--semantic-border-default, #E4E4E7); background-color: color-mix(in srgb, var(--semantic-surface-card, #FFFFFF) 80%, transparent);"
  >
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
      <a href="/" class="text-lg font-bold">ReadMigo Brand Hub</a>
      <div class="flex gap-6 text-sm">
        <a href="/tokens/colors">Tokens</a>
        <a href="/components/buttons">Components</a>
        <a href="/assets">Assets</a>
        <a href="/copy">Copy</a>
      </div>
    </div>
  </nav>
  <main class="mx-auto max-w-7xl px-6 py-8">
    <slot />
  </main>
</body>
</html>
