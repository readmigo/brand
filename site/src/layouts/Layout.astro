---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | ReadMigo Brand Hub</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen bg-[#F7F8FD] text-[#2D2E4A]">
  <nav class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
      <a href="/" class="text-lg font-bold">ReadMigo Brand Hub</a>
      <div class="flex gap-6 text-sm">
        <a href="/tokens/colors">Tokens</a>
        <a href="/components/buttons">Components</a>
        <a href="/assets">Assets</a>
        <a href="/copy">Copy</a>
      </div>
    </div>
  </nav>
  <main class="mx-auto max-w-7xl px-6 py-8">
    <slot />
  </main>
</body>
</html>
